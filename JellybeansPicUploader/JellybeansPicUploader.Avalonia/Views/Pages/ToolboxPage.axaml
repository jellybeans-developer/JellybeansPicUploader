<pages:PageHostBase xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pages="using:JellybeansPicUploader.Views.Pages"
                    x:Class="JellybeansPicUploader.Views.Pages.ToolboxPage">
    <Grid Margin="24" RowDefinitions="Auto,Auto,*">
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,0,0,12">
            <Button Content="选择图片"
                    Command="{Binding SelectToolboxFileCommand}"
                    MinHeight="36"
                    VerticalAlignment="Center"/>
            <Button Content="压缩并保存"
                    Command="{Binding RunToolboxCompressCommand}"
                    MinHeight="36"
                    VerticalAlignment="Center"/>
            <Button Content="转 Base64"
                    Command="{Binding RunToolboxBase64Command}"
                    MinHeight="36"
                    VerticalAlignment="Center"/>
            <Button Content="加水印并保存"
                    Command="{Binding RunToolboxWatermarkCommand}"
                    MinHeight="36"
                    VerticalAlignment="Center"/>
            <Button Content="复制 Base64"
                    Command="{Binding CopyToolboxBase64Command}"
                    MinHeight="36"
                    MinWidth="108"
                    VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Grid.Row="1" Margin="0,0,0,12" Opacity="0.75"
                   Text="{Binding ToolboxSourceFilePath, StringFormat=当前文件：{0}}"/>
        <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <Border Grid.Column="0" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="Base64 结果" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding ToolboxBase64Result}" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="200" IsReadOnly="True"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="输出文件" FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding ToolboxProcessedFiles}" MinHeight="200"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</pages:PageHostBase>
