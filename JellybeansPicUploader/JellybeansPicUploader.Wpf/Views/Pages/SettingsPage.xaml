<pages:PageHostBase x:Class="JellybeansPicUploader.Views.Pages.SettingsPage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:pages="clr-namespace:JellybeansPicUploader.Views.Pages">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24">
        <wpfui:Card Margin="0,0,0,16">
            <StackPanel Margin="16">
                <wpfui:TextBlock Text="文件名规则" FontTypography="Subtitle" Margin="0,0,0,12"/>
                <wpfui:ToggleSwitch Content="启用 Hash（唯一文件名）" IsChecked="{Binding EnableHash}"/>
                <wpfui:ToggleSwitch Content="启用前缀" IsChecked="{Binding EnablePrefix}" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <wpfui:TextBlock Text="前缀" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <wpfui:TextBox Width="200" Text="{Binding ImageNamePrefix, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </StackPanel>
        </wpfui:Card>

        <wpfui:Card Margin="0,0,0,16">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <wpfui:TextBlock Text="压缩" FontTypography="Subtitle" Margin="0,0,0,12"/>
                    <wpfui:ToggleSwitch Content="上传前压缩" IsChecked="{Binding EnableCompress}"/>
                    <wpfui:TextBlock Text="压缩编码器" Margin="0,12,0,4"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource CompressEncoderValues}}"
                              SelectedItem="{Binding CompressEncoder}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <wpfui:TextBlock Text="水印" FontTypography="Subtitle" Margin="0,0,0,12"/>
                    <wpfui:ToggleSwitch Content="上传前加水印" IsChecked="{Binding EnableWatermark}"/>
                    <wpfui:TextBlock Text="水印文字" Margin="0,12,0,4"/>
                    <wpfui:TextBox Text="{Binding WatermarkText, UpdateSourceTrigger=PropertyChanged}"/>
                    <wpfui:TextBlock Text="字号 / 位置 / 颜色 / 透明度" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <wpfui:TextBox Width="60" Text="{Binding WatermarkFontSize}"/>
                        <ComboBox Width="130" Margin="8,0,0,0"
                                  ItemsSource="{Binding Source={StaticResource WatermarkPositionValues}}"
                                  SelectedItem="{Binding WatermarkPosition}"/>
                        <wpfui:TextBox Width="80" Margin="8,0,0,0" Text="{Binding WatermarkTextColorHex}"/>
                        <wpfui:TextBox Width="60" Margin="8,0,0,0" Text="{Binding WatermarkOpacity}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </wpfui:Card>

        <wpfui:Card Margin="0,0,0,16">
            <StackPanel Margin="16">
                <wpfui:TextBlock Text="链接规则" FontTypography="Subtitle" Margin="0,0,0,12"/>
                <wpfui:TextBlock Text="链接规则" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding LinkRuleNames}" SelectedItem="{Binding SelectedLinkRuleName}"/>
                <wpfui:ToggleSwitch Content="启用 Markdown/HTML/UBB/Custom 格式包装" IsChecked="{Binding EnableLinkFormat}" Margin="0,12,0,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource ImageLinkFormatValues}}"
                          SelectedItem="{Binding SelectedLinkFormat}" Margin="0,8,0,0"/>
                <wpfui:TextBlock Text="自定义格式模板（占位符 imageLink、imageName）" Margin="0,12,0,4"/>
                <wpfui:TextBox Text="{Binding CustomLinkFormatTemplate, UpdateSourceTrigger=PropertyChanged}"/>
                <wpfui:ToggleSwitch Content="上传后自动复制链接" IsChecked="{Binding AutoCopyLinkAfterUpload}" Margin="0,12,0,0"/>
                <wpfui:TextBlock Text="自定义规则模板（需包含 {{path}}）" Margin="0,16,0,4"/>
                <wpfui:TextBox Text="{Binding CustomLinkRuleTemplate, UpdateSourceTrigger=PropertyChanged}"/>
                <wpfui:Button Content="添加自定义规则" Margin="0,12,0,0" HorizontalAlignment="Left"
                           Command="{Binding AddCustomLinkRuleCommand}"/>
            </StackPanel>
        </wpfui:Card>

        <wpfui:Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Icon="{wpfui:SymbolIcon Save24}"/>
    </StackPanel>
    </ScrollViewer>
</pages:PageHostBase>
