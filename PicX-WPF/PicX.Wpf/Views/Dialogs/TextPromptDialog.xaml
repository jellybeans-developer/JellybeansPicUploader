<Window x:Class="PicXWpf.Views.Dialogs.TextPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="输入"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="420"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <wpfui:TextBlock x:Name="PromptTextBlock" Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <wpfui:TextBox x:Name="InputTextBox"
                    Grid.Row="1"
                    MinWidth="360"
                    Margin="0,0,0,16"
                    KeyDown="InputTextBox_OnKeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <wpfui:Button Content="取消" Margin="0,0,8,0" Click="CancelButton_OnClick"/>
            <wpfui:Button Content="确定" Appearance="Primary" Click="ConfirmButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
