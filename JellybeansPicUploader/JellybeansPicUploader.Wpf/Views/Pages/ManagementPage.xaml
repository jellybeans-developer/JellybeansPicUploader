<pages:PageHostBase x:Class="JellybeansPicUploader.Views.Pages.ManagementPage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:pages="clr-namespace:JellybeansPicUploader.Views.Pages">
    <pages:PageHostBase.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </pages:PageHostBase.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,16">
            <wpfui:Button Content="刷新"
                          Command="{Binding RefreshManagedImagesCommand}"
                          Icon="{wpfui:SymbolIcon ArrowSync24}"
                          Margin="0,0,8,8"/>
            <wpfui:Button Content="全选"
                          Command="{Binding SelectAllManagedImagesCommand}"
                          Margin="0,0,8,8"/>
            <wpfui:Button Content="取消选择"
                          Command="{Binding ClearManagedImageSelectionCommand}"
                          Margin="0,0,8,8"/>
            <wpfui:Button Content="删除选中"
                          Command="{Binding DeleteSelectedImagesCommand}"
                          Appearance="Danger"
                          Icon="{wpfui:SymbolIcon Delete24}"
                          Margin="0,0,8,8"/>
            <wpfui:Button Content="复制选中链接"
                          Command="{Binding CopySelectedImageLinksCommand}"
                          Icon="{wpfui:SymbolIcon Link24}"
                          Margin="0,0,8,8"/>
        </WrapPanel>

        <wpfui:Card Grid.Row="1" Padding="12">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ManagedImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="168"
                                        Height="200"
                                        Margin="8"
                                        CornerRadius="8"
                                        Background="#2A2A2A"
                                        BorderBrush="#44FFFFFF"
                                        BorderThickness="1"
                                        ToolTip="{Binding Name}">
                                    <Grid>
                                        <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,28">
                                            <Grid Background="#1E1E1E">
                                                <Image Source="{Binding ThumbnailSource}"
                                                       Stretch="Uniform"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsThumbnailLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <wpfui:ProgressRing IsIndeterminate="True" Width="28" Height="28"/>
                                                </StackPanel>

                                                <wpfui:SymbolIcon Symbol="Image24"
                                                               FontSize="36"
                                                               Foreground="#66FFFFFF"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                    <wpfui:SymbolIcon.Style>
                                                        <Style TargetType="wpfui:SymbolIcon">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding ThumbnailSource}" Value="{x:Null}"/>
                                                                        <Condition Binding="{Binding IsThumbnailLoading}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </wpfui:SymbolIcon.Style>
                                                </wpfui:SymbolIcon>

                                                <Border Background="#66000000"
                                                        Visibility="{Binding IsDeleting, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <wpfui:TextBlock Text="删除中…"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="#FFFFFF"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="8,8,0,0"
                                                  Panel.ZIndex="2"/>

                                        <wpfui:TextBlock Text="{Binding Name}"
                                                      TextTrimming="CharacterEllipsis"
                                                      MaxWidth="152"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Bottom"
                                                      Margin="8,0,8,8"
                                                      Appearance="Secondary"
                                                      FontTypography="Caption"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <wpfui:TextBlock Text="仓库中暂无图片，请先在「上传」页添加图片。"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Appearance="Secondary"
                              Visibility="{Binding IsManagedImageGalleryEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Border Background="#99000000"
                        CornerRadius="8"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <wpfui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
                        <wpfui:TextBlock Text="正在加载图片列表…"
                                      Margin="0,12,0,0"
                                      HorizontalAlignment="Center"
                                      Foreground="#FFFFFF"/>
                    </StackPanel>
                </Border>
            </Grid>
        </wpfui:Card>

        <wpfui:TextBlock Grid.Row="2"
                      Margin="0,12,0,0"
                      Appearance="Secondary"
                      Text="{Binding ManagedImageGallerySummary}"/>
    </Grid>
</pages:PageHostBase>
