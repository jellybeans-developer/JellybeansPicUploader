<pages:PageHostBase xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pages="using:JellybeansPicUploader.Views.Pages"
                    xmlns:resources="using:JellybeansPicUploader.Resources"
                    x:Class="JellybeansPicUploader.Views.Pages.SettingsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">
            <Border Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="文件名规则" FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="启用 Hash（唯一文件名）" VerticalAlignment="Center"/>
                        <ToggleSwitch IsChecked="{Binding EnableHash}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="启用前缀" VerticalAlignment="Center"/>
                        <ToggleSwitch IsChecked="{Binding EnablePrefix}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="前缀" VerticalAlignment="Center"/>
                        <TextBox Width="200" Text="{Binding ImageNamePrefix}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="压缩" FontSize="18" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="上传前压缩" VerticalAlignment="Center"/>
                                <ToggleSwitch IsChecked="{Binding EnableCompress}"
                                              VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="压缩编码器" VerticalAlignment="Center"/>
                                <ComboBox MinWidth="160"
                                          ItemsSource="{x:Static resources:EnumBindingSource.CompressEncoderValues}"
                                          SelectedItem="{Binding CompressEncoder}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <TextBlock Text="水印" FontSize="18" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="上传前加水印" VerticalAlignment="Center"/>
                            <ToggleSwitch IsChecked="{Binding EnableWatermark}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="水印文字" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding WatermarkText}" MinWidth="280"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Width="60" Text="{Binding WatermarkFontSize}"/>
                            <ComboBox Width="130"
                                      ItemsSource="{x:Static resources:EnumBindingSource.WatermarkPositionValues}"
                                      SelectedItem="{Binding WatermarkPosition}"/>
                            <TextBox Width="80" Text="{Binding WatermarkTextColorHex}"/>
                            <TextBox Width="60" Text="{Binding WatermarkOpacity}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="链接规则" FontSize="18" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding LinkRuleNames}" SelectedItem="{Binding SelectedLinkRuleName}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="启用 Markdown/HTML/UBB/Custom 格式包装" VerticalAlignment="Center"/>
                        <ToggleSwitch IsChecked="{Binding EnableLinkFormat}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{x:Static resources:EnumBindingSource.ImageLinkFormatValues}"
                              SelectedItem="{Binding SelectedLinkFormat}"/>
                    <TextBox Text="{Binding CustomLinkFormatTemplate}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="上传后自动复制链接" VerticalAlignment="Center"/>
                        <ToggleSwitch IsChecked="{Binding AutoCopyLinkAfterUpload}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding CustomLinkRuleTemplate}"/>
                    <Button Content="添加自定义规则" Command="{Binding AddCustomLinkRuleCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</pages:PageHostBase>
