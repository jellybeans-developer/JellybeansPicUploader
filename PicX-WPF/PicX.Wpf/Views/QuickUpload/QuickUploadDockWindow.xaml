<Window x:Class="PicXWpf.Views.QuickUpload.QuickUploadDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PicX 快捷上传"
        Width="52"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowActivated="True">
    <Border x:Name="DockNoteBorder"
            CornerRadius="10,10,4,4"
            Background="#FF3D3D42"
            BorderBrush="#88FFFFFF"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="DockNoteBorder_OnMouseLeftButtonDown"
            MouseLeftButtonUp="DockNoteBorder_OnMouseLeftButtonUp"
            ToolTip="单击快捷上传；双击恢复主窗口">
        <Grid>
            <Rectangle Margin="0,0,0,6"
                       VerticalAlignment="Bottom"
                       Height="6"
                       RadiusX="2"
                       RadiusY="2"
                       Fill="#55FFFFFF"
                       Opacity="0.35"
                       IsHitTestVisible="False"/>
            <TextBlock Text="+"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#FFE8E8E8"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-2,0,0"
                       IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>
