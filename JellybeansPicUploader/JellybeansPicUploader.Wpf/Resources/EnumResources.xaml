<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:JellybeansPicUploader.Models">
    <ObjectDataProvider x:Key="DirectoryModeValues" MethodName="GetValues" ObjectType="{x:Type models:DirectoryMode}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="models:DirectoryMode"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="CompressEncoderValues" MethodName="GetValues" ObjectType="{x:Type models:CompressEncoder}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="models:CompressEncoder"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="WatermarkPositionValues" MethodName="GetValues" ObjectType="{x:Type models:WatermarkPosition}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="models:WatermarkPosition"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="ImageLinkFormatValues" MethodName="GetValues" ObjectType="{x:Type models:ImageLinkFormatType}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="models:ImageLinkFormatType"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
</ResourceDictionary>
