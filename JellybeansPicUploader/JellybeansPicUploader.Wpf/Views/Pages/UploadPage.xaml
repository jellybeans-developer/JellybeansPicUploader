<pages:PageHostBase x:Class="JellybeansPicUploader.Views.Pages.UploadPage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:pages="clr-namespace:JellybeansPicUploader.Views.Pages"
                    xmlns:converters="clr-namespace:JellybeansPicUploader.Converters">
    <pages:PageHostBase.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter"/>
    </pages:PageHostBase.Resources>

    <Grid Margin="24"
          Focusable="True"
          PreviewKeyDown="UploadPage_OnPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 虚线拖放区 -->
        <Grid x:Name="UploadDropZone"
              Grid.Row="0"
              MinHeight="148"
              Margin="0,0,0,16"
              AllowDrop="True"
              Cursor="Hand"
              MouseLeftButtonUp="UploadDropZone_OnMouseLeftButtonUp"
              DragOver="UploadArea_OnDragOver"
              DragLeave="UploadArea_OnDragLeave"
              Drop="UploadArea_OnDrop">
            <Rectangle RadiusX="12"
                       RadiusY="12"
                       Stroke="#99FFFFFF"
                       StrokeThickness="2"
                       StrokeDashArray="8 4"
                       Fill="Transparent"
                       IsHitTestVisible="False"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                <wpfui:SymbolIcon Symbol="CloudArrowUp48"
                               FontSize="52"
                               Foreground="#CCFFFFFF"
                               HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <wpfui:TextBlock Text="将文件拖拽到此处，或 "
                                  VerticalAlignment="Center"
                                  Appearance="Secondary"/>
                    <wpfui:Button Content="点击上传"
                               Appearance="Transparent"
                               Padding="0,0,0,2"
                               FontSize="14"
                               Foreground="#FF4FC3F7"
                               Command="{Binding AddImagesCommand}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <Border x:Name="UploadDropOverlay"
                    Background="#B34FC3F7"
                    BorderBrush="#FF4FC3F7"
                    BorderThickness="2"
                    CornerRadius="12"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="ArrowUpload24" FontSize="36" Foreground="#FFFFFF"/>
                    <wpfui:TextBlock Text="松开鼠标添加图片"
                                  Foreground="#FFFFFF"
                                  FontTypography="BodyStrong"
                                  HorizontalAlignment="Center"
                                  Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 链接格式 + 快捷上传（标题与操作区分行，保证左右上下对齐） -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <wpfui:TextBlock Grid.Row="0"
                             Grid.Column="0"
                             Text="链接格式"
                             FontTypography="Caption"
                             Appearance="Secondary"
                             Margin="0,0,0,8"/>
            <wpfui:TextBlock Grid.Row="0"
                             Grid.Column="1"
                             Text="快捷上传"
                             FontTypography="Caption"
                             Appearance="Secondary"
                             Margin="24,0,0,8"/>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    CornerRadius="18"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    Background="#14FFFFFF"
                    Padding="3"
                    HorizontalAlignment="Left"
                    ClipToBounds="False">
                <WrapPanel Orientation="Horizontal">
                    <RadioButton Content="Markdown"
                                 GroupName="UploadLinkFormat"
                                 Margin="2,0"
                                 Padding="12,6"
                                 MinWidth="88"
                                 Command="{Binding SelectUploadLinkFormatCommand}"
                                 CommandParameter="Markdown"
                                 IsChecked="{Binding SelectedUploadLinkFormatOption, Mode=OneWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Markdown}"/>
                    <RadioButton Content="HTML"
                                 GroupName="UploadLinkFormat"
                                 Margin="2,0"
                                 Padding="12,6"
                                 MinWidth="64"
                                 Command="{Binding SelectUploadLinkFormatCommand}"
                                 CommandParameter="HTML"
                                 IsChecked="{Binding SelectedUploadLinkFormatOption, Mode=OneWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=HTML}"/>
                    <RadioButton Content="URL"
                                 GroupName="UploadLinkFormat"
                                 Margin="2,0"
                                 Padding="12,6"
                                 MinWidth="56"
                                 Command="{Binding SelectUploadLinkFormatCommand}"
                                 CommandParameter="URL"
                                 IsChecked="{Binding SelectedUploadLinkFormatOption, Mode=OneWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=URL}"/>
                    <RadioButton Content="UBB"
                                 GroupName="UploadLinkFormat"
                                 Margin="2,0"
                                 Padding="12,6"
                                 MinWidth="56"
                                 Command="{Binding SelectUploadLinkFormatCommand}"
                                 CommandParameter="UBB"
                                 IsChecked="{Binding SelectedUploadLinkFormatOption, Mode=OneWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=UBB}"/>
                    <RadioButton Content="Custom"
                                 GroupName="UploadLinkFormat"
                                 Margin="2,0"
                                 Padding="12,6"
                                 MinWidth="76"
                                 Command="{Binding SelectUploadLinkFormatCommand}"
                                 CommandParameter="Custom"
                                 IsChecked="{Binding SelectedUploadLinkFormatOption, Mode=OneWay, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Custom}"/>
                </WrapPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Margin="24,0,0,0"
                        VerticalAlignment="Center">
                <wpfui:Button Content="剪贴板图片"
                           Command="{Binding PasteImagesFromClipboardCommand}"
                           Appearance="Primary"
                           Padding="16,8"
                           Margin="0,0,8,0"/>
                <wpfui:Button Content="URL"
                           Command="{Binding ImportImageFromUrlCommand}"
                           Appearance="Primary"
                           Padding="16,8"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,0,0,12"
                    Visibility="{Binding IsCustomUploadLinkFormatPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <wpfui:TextBlock Text="自定义格式（占位符 imageLink、imageName）" FontTypography="Caption" Appearance="Secondary" Margin="0,0,0,4"/>
            <wpfui:TextBox Text="{Binding CustomLinkFormatTemplate, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <WrapPanel Grid.Row="3" Margin="0,0,0,12">
            <wpfui:Button Content="全选" Command="{Binding SelectAllUploadItemsCommand}" Margin="0,0,8,8"/>
            <wpfui:Button Content="取消全选" Command="{Binding ClearUploadItemSelectionCommand}" Margin="0,0,8,8"/>
            <wpfui:Button Content="移除选中" Command="{Binding RemoveSelectedUploadCommand}" Margin="0,0,8,8"/>
            <wpfui:Button Content="清空列表" Command="{Binding ClearUploadListCommand}" Margin="0,0,8,8"/>
            <wpfui:Button Content="开始上传" Command="{Binding UploadImagesCommand}" Appearance="Primary"
                       Icon="{wpfui:SymbolIcon CloudArrowUp24}" Margin="0,0,8,8"/>
            <wpfui:Button Content="取消" Command="{Binding CancelOperationCommand}" Margin="0,0,8,8"/>
            <wpfui:Button Content="复制最后链接" Command="{Binding CopyLastLinkCommand}" Icon="{wpfui:SymbolIcon Link24}"/>
        </WrapPanel>

        <wpfui:Card Grid.Row="4" Padding="0">
            <Grid AllowDrop="True"
                  DragOver="UploadArea_OnDragOver"
                  DragLeave="UploadArea_OnDragLeave"
                  Drop="UploadArea_OnDrop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10" BorderBrush="#28FFFFFF" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <wpfui:TextBlock Grid.Column="0" Text="选中" FontTypography="Caption" Appearance="Secondary"/>
                        <wpfui:TextBlock Grid.Column="1" Text="本地文件" FontTypography="Caption" Appearance="Secondary" Margin="8,0,0,0"/>
                        <wpfui:TextBlock Grid.Column="2" Text="远端文件名" FontTypography="Caption" Appearance="Secondary" Margin="8,0,0,0"/>
                        <wpfui:TextBlock Grid.Column="3" Text="状态" FontTypography="Caption" Appearance="Secondary" Margin="8,0,0,0"/>
                        <wpfui:TextBlock Grid.Column="4" Text="链接" FontTypography="Caption" Appearance="Secondary" Margin="8,0,0,0"/>
                        <wpfui:TextBlock Grid.Column="5" Text="错误" FontTypography="Caption" Appearance="Secondary" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <ListBox x:Name="UploadItemsList"
                         Grid.Row="1"
                         ItemsSource="{Binding UploadItems}"
                         SelectedItem="{Binding SelectedUploadItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="False">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,4">
                                <Grid MinHeight="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              PreviewMouseLeftButtonDown="UploadItemCheckBox_OnPreviewMouseLeftButtonDown"/>

                                    <wpfui:TextBlock Grid.Column="1"
                                                  Margin="8,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding DisplayFileName}"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding DisplayFileName}"/>

                                    <wpfui:TextBox Grid.Column="2"
                                                Margin="0,8,8,8"
                                                VerticalAlignment="Center"
                                                Text="{Binding RemoteFileName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <wpfui:TextBlock Grid.Column="3"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding Status}"/>

                                    <Grid Grid.Column="4" Margin="0,8,8,8" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <wpfui:TextBlock Grid.Column="0"
                                                      Text="{Binding ImageUrl}"
                                                      TextTrimming="CharacterEllipsis"
                                                      ToolTip="{Binding ImageUrl}"
                                                      VerticalAlignment="Center"/>
                                        <wpfui:Button Grid.Column="1"
                                                   Content="复制"
                                                   Margin="8,0,0,0"
                                                   Padding="10,4"
                                                   Command="{Binding DataContext.CopyUploadItemGitHubPagesLinkCommand, ElementName=UploadItemsList}"
                                                   CommandParameter="{Binding}"
                                                   Icon="{wpfui:SymbolIcon Copy24}"/>
                                    </Grid>

                                    <wpfui:TextBlock Grid.Column="5"
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center"
                                                  Text="{Binding ErrorMessage}"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding ErrorMessage}"/>
                                </Grid>

                                <ProgressBar Height="6"
                                             Margin="12,0,12,4"
                                             Minimum="0"
                                             Maximum="100"
                                             Foreground="#FF4FC3F7"
                                             Background="#33FFFFFF"
                                             Visibility="{Binding IsUploadInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </wpfui:Card>

        <wpfui:TextBlock Grid.Row="5" Margin="0,12,0,0" Appearance="Secondary"
                      Text="提示：可将图片拖到上方虚线框或列表区域；Ctrl+V 粘贴剪贴板；链接格式影响上传后复制与列表中的链接展示。"/>
    </Grid>
</pages:PageHostBase>
