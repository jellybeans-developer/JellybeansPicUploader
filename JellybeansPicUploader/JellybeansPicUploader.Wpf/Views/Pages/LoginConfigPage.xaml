<pages:PageHostBase x:Class="JellybeansPicUploader.Views.Pages.LoginConfigPage"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:pages="clr-namespace:JellybeansPicUploader.Views.Pages"
                    xmlns:models="clr-namespace:JellybeansPicUploader.Models">
    <pages:PageHostBase.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </pages:PageHostBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24">
        <wpfui:Card Margin="0,0,0,16">
            <StackPanel Margin="16">
                <wpfui:TextBlock Text="GitHub 登录" FontTypography="Subtitle" Margin="0,0,0,8"/>
                <wpfui:TextBlock TextWrapping="Wrap" Appearance="Secondary" Margin="0,0,0,16"
                              Text="点击「GitHub 授权登录」将打开浏览器完成授权，成功后自动获取 Token 并登录。"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <wpfui:Button Content="{Binding GitHubAuthorizeButtonText}"
                               Command="{Binding LoginWithGitHubAuthorizeCommand}"
                               Appearance="Primary" Icon="{wpfui:SymbolIcon PersonKey24}" Padding="20,8"/>
                    <wpfui:Button Content="安装 GitHub App" Margin="12,0,0,0"
                               Command="{Binding OpenInstallPageCommand}"
                               Icon="{wpfui:SymbolIcon AppsAddIn24}"/>
                </StackPanel>
                <wpfui:TextBlock Text="{Binding LoginDisplayName, StringFormat=当前用户：{0}}"
                              FontTypography="BodyStrong" Margin="0,8,0,0"/>
            </StackPanel>
        </wpfui:Card>

        <wpfui:CardExpander Icon="{wpfui:SymbolIcon Key24}" Margin="0,0,0,16">
            <wpfui:CardExpander.Header>
                <wpfui:TextBlock Text="手动填写 Token（高级）" FontTypography="Body"/>
            </wpfui:CardExpander.Header>
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <wpfui:TextBox Grid.Column="0" PlaceholderText="GitHub Personal Access Token"
                            Text="{Binding ManualToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <wpfui:Button Grid.Column="1" Content="Token 登录" Command="{Binding LoginWithManualTokenCommand}"/>
            </Grid>
        </wpfui:CardExpander>

        <wpfui:Card Margin="0,0,0,16">
            <StackPanel Margin="16">
                <wpfui:TextBlock Text="图床配置" FontTypography="Subtitle" Margin="0,0,0,4"/>
                <wpfui:TextBlock Text="首次填写后将自动保存，下次启动无需重复填写；修改后也会自动保存，也可点击「保存设置」立即写入。"
                              TextWrapping="Wrap" Appearance="Secondary" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <wpfui:TextBlock Text="Owner" Margin="0,0,0,4"/>
                        <wpfui:TextBox Text="{Binding Owner, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                        <wpfui:TextBlock Text="Repository" Margin="0,0,0,4"/>
                        <wpfui:TextBox Text="{Binding Repository, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                        <wpfui:TextBlock Text="Branch" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AvailableBranches}"
                                  Text="{Binding Branch, UpdateSourceTrigger=PropertyChanged}" IsEditable="True"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                        <wpfui:TextBlock Text="Email（可选）" Margin="0,0,0,4"/>
                        <wpfui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                        <wpfui:TextBlock Text="目录模式" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource DirectoryModeValues}}"
                                  SelectedItem="{Binding DirectoryMode}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                        <wpfui:TextBlock Text="目标目录" Margin="0,0,0,4"/>
                        <wpfui:TextBox Text="{Binding TargetDirectoryPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                        <wpfui:TextBlock Text="Commit Message" Margin="0,0,0,4"/>
                        <wpfui:TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                        <wpfui:TextBlock Text="上传后图片链接方式" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding PostUploadPublishMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="GitHub Pages（自动部署 gh-pages 分支）"
                                          Tag="{x:Static models:PostUploadPublishMode.GitHubPages}"/>
                            <ComboBoxItem Content="jsDelivr CDN（无需部署，使用 CDN 加速）"
                                          Tag="{x:Static models:PostUploadPublishMode.JsDelivr}"/>
                        </ComboBox>
                        <wpfui:TextBlock Text="上传成功后将按此方式生成链接；GitHub Pages 需约 1 分钟生效，jsDelivr 通常立即可用。"
                                      TextWrapping="Wrap" Appearance="Secondary" Margin="0,8,0,0"/>

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding IsJsDelivrVersionReferenceConfigurationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <wpfui:TextBlock Text="jsDelivr 版本引用（覆盖同路径图片时）" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding JsDelivrVersionReferenceMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="Commit Hash（推荐：每次上传新链接，更新后立即生效）"
                                              Tag="{x:Static models:JsDelivrVersionReferenceMode.CommitHash}"/>
                                <ComboBoxItem Content="Tag（固定 URL，上传后自动移动标签到最新提交）"
                                              Tag="{x:Static models:JsDelivrVersionReferenceMode.Tag}"/>
                                <ComboBoxItem Content="分支名（URL 不变，CDN 可能长时间缓存旧图）"
                                              Tag="{x:Static models:JsDelivrVersionReferenceMode.Branch}"/>
                            </ComboBox>
                            <wpfui:TextBlock Text="jsDelivr 按完整 URL 缓存。使用分支名时同一路径覆盖后，外链可能仍显示旧图；Commit Hash 每次生成新地址；Tag 在固定地址下需移动标签并等待 CDN 刷新。"
                                          TextWrapping="Wrap" Appearance="Secondary" Margin="0,8,0,0"/>

                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding IsJsDelivrTagNameConfigurationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <wpfui:TextBlock Text="Tag 名称（不含 refs/tags/ 前缀）" Margin="0,0,0,4"/>
                                <wpfui:TextBox Text="{Binding JsDelivrTagName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </wpfui:Card>

        <StackPanel Orientation="Horizontal">
            <wpfui:Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Icon="{wpfui:SymbolIcon Save24}"/>
            <wpfui:Button Content="退出登录" Margin="8,0,0,0" Command="{Binding LogoutCommand}"
                       Appearance="Secondary" Icon="{wpfui:SymbolIcon SignOut20}"/>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</pages:PageHostBase>
