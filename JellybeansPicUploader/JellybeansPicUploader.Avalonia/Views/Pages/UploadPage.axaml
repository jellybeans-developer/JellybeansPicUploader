<pages:PageHostBase xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pages="using:JellybeansPicUploader.Views.Pages"
                    xmlns:converters="using:JellybeansPicUploader.Converters"
                    x:Class="JellybeansPicUploader.Views.Pages.UploadPage"
                    Focusable="True"
                    KeyDown="UploadPage_OnKeyDown">
    <pages:PageHostBase.Resources>
        <converters:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter"/>
    </pages:PageHostBase.Resources>

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <Border x:Name="UploadDropZone" Grid.Row="0" MinHeight="148" Margin="0,0,0,16"
                Background="Transparent" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="2"
                CornerRadius="12" Cursor="Hand"
                PointerReleased="UploadDropZone_OnPointerReleased"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="UploadArea_OnDragOver"
                DragDrop.DragLeave="UploadArea_OnDragLeave"
                DragDrop.Drop="UploadArea_OnDrop">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24" Spacing="16">
                    <TextBlock Text="☁" FontSize="52" HorizontalAlignment="Center" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="0">
                        <TextBlock Text="将文件拖拽到此处，或" Opacity="0.75" VerticalAlignment="Center"/>
                        <Button Content="点击上传"
                                Classes="primary borderless"
                                Command="{Binding AddImagesCommand}"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="4,0,0,0"
                                Margin="0"
                                MinHeight="0"/>
                    </StackPanel>
                </StackPanel>
                <Border x:Name="UploadDropOverlay" Background="#332990FF" BorderBrush="{DynamicResource SemiBlue5}"
                        BorderThickness="2" CornerRadius="12" IsVisible="False" IsHitTestVisible="False">
                    <TextBlock Text="松开鼠标添加图片" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="链接格式" Opacity="0.75" Margin="0,0,0,8"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="快捷上传" Opacity="0.75" Margin="24,0,0,8"/>
            <WrapPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                <RadioButton Content="Markdown" GroupName="UploadLinkFormat" Margin="2"
                             Command="{Binding SelectUploadLinkFormatCommand}" CommandParameter="Markdown"
                             IsChecked="{Binding SelectedUploadLinkFormatOption, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Markdown}"/>
                <RadioButton Content="HTML" GroupName="UploadLinkFormat" Margin="2"
                             Command="{Binding SelectUploadLinkFormatCommand}" CommandParameter="HTML"
                             IsChecked="{Binding SelectedUploadLinkFormatOption, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=HTML}"/>
                <RadioButton Content="URL" GroupName="UploadLinkFormat" Margin="2"
                             Command="{Binding SelectUploadLinkFormatCommand}" CommandParameter="URL"
                             IsChecked="{Binding SelectedUploadLinkFormatOption, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=URL}"/>
                <RadioButton Content="UBB" GroupName="UploadLinkFormat" Margin="2"
                             Command="{Binding SelectUploadLinkFormatCommand}" CommandParameter="UBB"
                             IsChecked="{Binding SelectedUploadLinkFormatOption, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=UBB}"/>
                <RadioButton Content="Custom" GroupName="UploadLinkFormat" Margin="2"
                             Command="{Binding SelectUploadLinkFormatCommand}" CommandParameter="Custom"
                             IsChecked="{Binding SelectedUploadLinkFormatOption, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Custom}"/>
            </WrapPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0" Spacing="8">
                <Button Content="剪贴板图片" Classes="primary" Command="{Binding PasteImagesFromClipboardCommand}"/>
                <Button Content="URL" Classes="primary" Command="{Binding ImportImageFromUrlCommand}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,12" IsVisible="{Binding IsCustomUploadLinkFormatPanelVisible}">
            <TextBlock Text="自定义格式（占位符 imageLink、imageName）" Opacity="0.75" Margin="0,0,0,4"/>
            <TextBox Text="{Binding CustomLinkFormatTemplate}"/>
        </StackPanel>

        <WrapPanel Grid.Row="3" Margin="0,0,0,12">
            <Button Content="全选" Command="{Binding SelectAllUploadItemsCommand}" Margin="0,0,8,8"/>
            <Button Content="取消全选" Command="{Binding ClearUploadItemSelectionCommand}" Margin="0,0,8,8"/>
            <Button Content="移除选中" Command="{Binding RemoveSelectedUploadCommand}" Margin="0,0,8,8"/>
            <Button Content="清空列表" Command="{Binding ClearUploadListCommand}" Margin="0,0,8,8"/>
            <Button Content="开始上传" Classes="primary" Command="{Binding UploadImagesCommand}" Margin="0,0,8,8"/>
            <Button Content="取消" Command="{Binding CancelOperationCommand}" Margin="0,0,8,8"/>
            <Button Content="复制最后链接" Command="{Binding CopyLastLinkCommand}" Margin="0,0,8,8"/>
        </WrapPanel>

        <Border Grid.Row="4" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="UploadArea_OnDragOver"
                DragDrop.DragLeave="UploadArea_OnDragLeave"
                DragDrop.Drop="UploadArea_OnDrop">
            <ListBox x:Name="UploadItemsList" ItemsSource="{Binding UploadItems}"
                     SelectedItem="{Binding SelectedUploadItem}" MinHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,4" Spacing="4">
                            <Grid ColumnDefinitions="56,2*,2*,100,3*,2*" MinHeight="48">
                                <CheckBox Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected}"
                                          PointerPressed="UploadItemCheckBox_OnPointerPressed"/>
                                <TextBlock Grid.Column="1" Margin="8,0" VerticalAlignment="Center"
                                           Text="{Binding DisplayFileName}" TextTrimming="CharacterEllipsis"/>
                                <TextBox Grid.Column="2" Margin="0,8,8,8" VerticalAlignment="Center"
                                         Text="{Binding RemoteFileName}"/>
                                <TextBlock Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Center" Text="{Binding Status}"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,8,8,8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ImageUrl}" TextTrimming="CharacterEllipsis"/>
                                    <Button Content="复制" Margin="8,0,0,0"
                                            Command="{Binding #UploadItemsList.DataContext.CopyUploadItemGitHubPagesLinkCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="{Binding ErrorMessage}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <ProgressBar Height="6" Minimum="0" Maximum="100" Foreground="{DynamicResource SemiBlue5}"
                                         IsVisible="{Binding IsUploadInProgress}" Value="{Binding ProgressPercent}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="5" Margin="0,12,0,0" Opacity="0.75"
                   Text="提示：可将图片拖到虚线框或列表；Ctrl+V 粘贴剪贴板。"/>
    </Grid>
</pages:PageHostBase>
