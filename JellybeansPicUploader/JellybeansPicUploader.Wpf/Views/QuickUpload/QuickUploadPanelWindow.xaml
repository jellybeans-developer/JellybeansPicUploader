<Window x:Class="JellybeansPicUploader.Views.QuickUpload.QuickUploadPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="JellybeansPicUploader 快捷上传"
        Width="360"
        Height="168"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="True"
        PreviewKeyDown="QuickUploadPanelWindow_OnPreviewKeyDown">
    <Border CornerRadius="12"
            Background="#FF2B2B30"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            Padding="2">
        <Grid x:Name="QuickUploadDropZone"
              MinHeight="148"
              AllowDrop="True"
              Cursor="Hand"
              MouseLeftButtonUp="QuickUploadDropZone_OnMouseLeftButtonUp"
              DragOver="QuickUploadDropZone_OnDragOver"
              DragLeave="QuickUploadDropZone_OnDragLeave"
              Drop="QuickUploadDropZone_OnDrop">
            <Rectangle RadiusX="12"
                       RadiusY="12"
                       Stroke="#99FFFFFF"
                       StrokeThickness="2"
                       StrokeDashArray="8 4"
                       Fill="Transparent"
                       IsHitTestVisible="False"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <wpfui:SymbolIcon Symbol="CloudArrowUp48"
                                  FontSize="44"
                                  Foreground="#CCFFFFFF"
                                  HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0">
                    <TextBlock Text="将文件拖拽到此处，或 "
                               VerticalAlignment="Center"
                               Foreground="#99FFFFFF"
                               FontSize="13"/>
                    <TextBlock Text="点击上传"
                               VerticalAlignment="Center"
                               Foreground="#FF4FC3F7"
                               FontSize="13"
                               Cursor="Hand"
                               MouseLeftButtonUp="ClickUploadText_OnMouseLeftButtonUp"/>
                </StackPanel>
            </StackPanel>

            <Border x:Name="QuickUploadDropOverlay"
                    Background="#B34FC3F7"
                    BorderBrush="#FF4FC3F7"
                    BorderThickness="2"
                    CornerRadius="12"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="ArrowUpload24" FontSize="32" Foreground="#FFFFFF"/>
                    <TextBlock Text="松开鼠标添加并上传"
                               Foreground="#FFFFFF"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
